<div class="flex justify-center items-center flex-col">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>
  <h1 class="font-bold text-4xl">Edit post</h1>
  <%= form_with model: @post, class: "grid grid-rows-auto gap-y-6" do |form| %>
    <div>
      <%= form.label :title, class: "block text-sm/6 font-medium"%>
      <%= form.text_field :title, class: "w-full px-2 py-1 text-sm text-gray-900 rounded bg-gray-50" %>
    </div>
    <div>
      <%= form.label :body,  class: "block text-sm/6 font-medium"%>
      <%= form.text_field :body ,class: "w-full px-2 py-1 text-sm text-gray-900 rounded bg-gray-50"%>
    </div>
    <%= form.submit 'Submit', class: "inline-flex items-center rounded bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
  <% end %>
</div>
