<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl"> Create Account </h1>
  <%= form_with url: registrations_path, model: @user do |f| %>
    <%= f.email_field :email_address, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full",
      placeholder: "Enter your email" %>
    <%= f.password_field :password, class:"block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full",
      placeholder: "Enter a password" %>
    <div class="flex items-center gap-4">
      <%= f.submit "Sign up", class: "inline-flex items-center rounded bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
      <%= link_to "Log in", new_session_path, class: "px-3 py-2 rounded-lg bg-blue-500 text-blue-50 cursor-pointer hover:bg-blue-600 transition duration-250" %>
    </div>
  <% end %>
</div>

