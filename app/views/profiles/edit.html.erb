<div class="flex justify-center items-center flex-col mx-auto max-w-2xl">
  <h1 class="font-bold text-4xl mb-12">Update Profile</h1>
  <% if @user.errors.any? %>
    <div class="text-red-500 mb-6">
      <h2><%= pluralize(@user.errors.count, "error") %> prevented your profile from being updated:</h2>
      <ul>
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%= form_with model: @user, url: profile_path, method: :patch, class: "grid grid-rows-auto gap-y-6 w-full" do |form| %>
    <div>
      <%= form.label :email_address, class: "block text-sm/6 font-medium" %>
      <%= form.text_field :email_address, class: "w-full px-2 py-1 text-sm text-gray-900 rounded bg-gray-50" %>
    </div>
    <%= form.submit "Update Profile", class: "inline-flex items-center rounded bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
  <% end %>
</div>
